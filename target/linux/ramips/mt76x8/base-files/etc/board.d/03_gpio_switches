. /lib/functions/uci-defaults.sh

board_config_update

board=$(board_name)

case "$board" in
teltonika,rut241|\
teltonika,rut200)
	ucidef_add_gpio_switch "DOUT" "DOUT" "524" "0"
	ucidef_add_gpio_switch "modem_pwr" "Modem power" "531" "1"
	ucidef_add_gpio_switch "modem_rst" "Modem reset" "530" "0"
	;;
esac

board_config_flush

exit 0
