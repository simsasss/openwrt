/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/leds/common.h>
#include "mt7628an.dtsi"

/ {
	chosen {
		bootargs = "console=ttyS0,115200";
	};

	aliases {
		led-boot = &led_power;
		led-failsafe = &led_power;
		led-upgrade = &led_power;
		led-running = &led_power;
	};

	ext_io {
		compatible = "spi-gpio";
		#address-cells = <1>;
		#size-cells = <0>;

		sck-gpios = <&gpio 3 GPIO_ACTIVE_HIGH>;  // SRCLK
		mosi-gpios = <&gpio 1 GPIO_ACTIVE_HIGH>; // SER
		cs-gpios = <&gpio 2 GPIO_ACTIVE_HIGH>;  // RCLK
		num-chipselects = <1>;

		shift_io: shift_io@0 {
			compatible = "fairchild,74hc595";
			reg = <0>;
			gpio-controller;
			#gpio-cells = <2>;
			registers-number = <2>;
			spi-max-frequency = <10000000>;
		};
	};

	gpio-export {
		compatible = "gpio-export";
		#size-cells = <0>;

		gpio_modem_reset {
			gpio-export,name = "modem_reset";
			gpio-export,output = <0>;
			gpios = <&shift_io 11 GPIO_ACTIVE_HIGH>;
		};

		gpio_modem_power {
			gpio-export,name = "modem_power";
			gpio-export,output = <0>;
			gpios = <&shift_io 10 GPIO_ACTIVE_HIGH>;
		};

		gpio_sim_select {
			gpio-export,name = "sim_sel";
			gpio-export,output = <1>;
			gpios = <&shift_io 7 GPIO_ACTIVE_LOW>;
		};

		gpio_sim_select_2 {
			gpio-export,name = "sim_sel2";
			gpio-export,output = <0>;
			gpios = <&gpio 6 GPIO_ACTIVE_HIGH>;
		};

		gpio_modem_status { // From v5
			gpio-export,name = "modem_status";
			gpio-export,input = <0>;
			gpios = <&gpio 0 GPIO_ACTIVE_LOW>;
		};

		gpio_dcd {
			gpio-export,name = "dcd";
			gpio-export,output = <0>;
			gpios = <&shift_io 14 GPIO_ACTIVE_HIGH>;
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio 38 GPIO_ACTIVE_LOW>;
			debounce-interval = <60>;
		};
	};

	leds {
		compatible = "gpio-leds";

		lan1 {
			function = LED_FUNCTION_LAN;
			color = <LED_COLOR_ID_GREEN>;
			function-enumerator = <1>;
			gpios = <&gpio 43 GPIO_ACTIVE_LOW>;
		};

		lan2 {
			function = LED_FUNCTION_LAN;
			color = <LED_COLOR_ID_GREEN>;
			function-enumerator = <2>;
			gpios = <&gpio 42 GPIO_ACTIVE_LOW>;
		};

		lan3 {
			function = LED_FUNCTION_LAN;
			color = <LED_COLOR_ID_GREEN>;
			function-enumerator = <3>;
			gpios = <&gpio 41 GPIO_ACTIVE_LOW>;
		};

		wan {
			function = LED_FUNCTION_WAN;
			color = <LED_COLOR_ID_GREEN>;
			gpios = <&gpio 39 GPIO_ACTIVE_LOW>;
		};

		gen_2_3 {
			label = "mob_gen_2_3";
			gpios = <&shift_io 5 GPIO_ACTIVE_HIGH>;
		};

		gen_4_3 {
			label = "mob_gen_4_3";
			gpios = <&shift_io 6 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_1: ssid_1 {
			label = "mob_ssid_1";
			gpios = <&shift_io 0 GPIO_ACTIVE_HIGH>;
		};

		ssid_2 {
			label = "mob_ssid_2";
			gpios = <&shift_io 1 GPIO_ACTIVE_HIGH>;
		};

		ssid_3 {
			label = "mob_ssid_3";
			gpios = <&shift_io 2 GPIO_ACTIVE_HIGH>;
		};

		ssid_4 {
			label = "mob_ssid_4";
			gpios = <&shift_io 3 GPIO_ACTIVE_HIGH>;
		};

		ssid_5 {
			label = "mob_ssid_5";
			gpios = <&shift_io 4 GPIO_ACTIVE_HIGH>;
		};

		led_power: power {
			gpios = <&shift_io 15 GPIO_ACTIVE_LOW>;
			function = LED_FUNCTION_POWER;
			color = <LED_COLOR_ID_GREEN>;
		};
	};
};

&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <10000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			boot: boot: partition@0 {
				label = "u-boot";
				reg = <0x0 0x20000>;
				read-only;
			};

			config: partition@20000 {
				compatible = "nvmem-cells";
				#address-cells = <1>;
				#size-cells = <1>;

				label = "config";
				reg = <0x020000 0x010000>;
				read-only;

				macaddr_config_0: macaddr@0 {
					reg = <0x0 0x6>;
				};
			};

			factory: partition@30000 {
				label = "factory";
				reg = <0x030000 0x030000>;
				read-only;
			};

			partition@60000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x060000 0xf10000>;
			};

			partition@f70000 {
				label = "event-log";
				reg = <0xf70000 0x90000>;
			};
		};
	};
};

&wmac {
	status = "okay";
	nvmem-cells = <&macaddr_config_0>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <2>;
	mediatek,mtd-eeprom = <&factory 0x20000>;
};

&ethernet {
	nvmem-cells = <&macaddr_config_0>;
	nvmem-cell-names = "mac-address";
};

&esw {
	mediatek,portmap = <0x2f>;
};

&i2c {
	status = "okay";
	hwmon@0x4d {
		compatible = "mcp3221";
		reg = <0x4d>;
		reference-voltage-microvolt = <3300000>;
	};

	hwmon@0x48 {
		compatible = "ti,tla2021";
		reg = <0x48>;
	};
};

&uart1 {
	linux,rs485-enabled-at-boot-time;
	rs485-rts-delay = <0 0>;
	rs485-rx-during-tx;
	rts-gpios = <&gpio 44 GPIO_ACTIVE_HIGH>;
	status = "okay";
};
