/dts-v1/;

#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include "mt7628an.dtsi"

/ {
	chosen {
		bootargs = "console=ttyS0,115200";
	};

	aliases {
		led-boot = &led_ssid_1;
		led-failsafe = &led_ssid_1;
		led-upgrade = &led_ssid_1;
	};

	gpio-export {
		compatible = "gpio-export";
		#size-cells = <0>;

		gpio_modem_reset {
		gpio-export,name = "modem_reset";
		gpio-export,output = <0>;
		gpios = <&gpio 2 GPIO_ACTIVE_HIGH>;
		};

		gpio_modem_power {
		gpio-export,name = "modem_power";
		gpio-export,output = <0>;
		gpios = <&gpio 3 GPIO_ACTIVE_HIGH>;
		};
	};

	keys {
		compatible = "gpio-keys";

		reset {
			label = "reset";
			gpios = <&gpio 46 GPIO_ACTIVE_LOW>;
			linux,code = <KEY_RESTART>;
		};
	};

	leds {
		compatible = "gpio-leds";

		eth1_led {
			label = "green:lan";
			gpios = <&gpio 42 GPIO_ACTIVE_LOW>;
		};

		eth2_led {
			label = "green:wan";
			gpios = <&gpio 43 GPIO_ACTIVE_LOW>;
		};

		led_gen_2 {
			label = "mob_gen_2";
			gpios = <&gpio 39 GPIO_ACTIVE_HIGH>;
		};

		led_gen_3 {
			label = "mob_gen_3";
			gpios = <&gpio 40 GPIO_ACTIVE_HIGH>;
		};

		led_gen_4 {
			label = "mob_gen_4";
			gpios = <&gpio 41 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_1: led_ssid_1 {
			label = "mob_ssid_1";
			gpios = <&gpio 11 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_2 {
			label = "mob_ssid_2";
			gpios = <&gpio 44 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_3 {
			label = "mob_ssid_3";
			gpios = <&gpio 36 GPIO_ACTIVE_LOW>;
		};

		led_ssid_4 {
			label = "mob_ssid_4";
			gpios = <&gpio 1 GPIO_ACTIVE_HIGH>;
		};

		led_ssid_5 {
			label = "mob_ssid_5";
			gpios = <&gpio 45 GPIO_ACTIVE_LOW>;
		};
	};
};

&pcie {
	status = "okay";
};

&pcie0 {
	mt76@0,0 {
		reg = <0x0000 0 0 0 0>;
		ieee80211-freq-limit = <5000000 6000000>;
		mediatek,mtd-eeprom = <&factory 0x28000>;
		nvmem-cells = <&macaddr_config_0>;
		nvmem-cell-names = "mac-address";
		mac-address-increment = <(-1)>;
	};
};

&spi0 {
	status = "okay";

	flash@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <10000000>;

		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			boot: partition@0 {
				label = "u-boot";
				reg = <0x0 0x20000>;
				read-only;
			};

			config: partition@20000 {
				compatible = "nvmem-cells";
				#address-cells = <1>;
				#size-cells = <1>;

				label = "config";
				reg = <0x020000 0x010000>;
				read-only;

				macaddr_config_0: macaddr@0 {
					reg = <0x0 0x6>;
				};
			};

			factory: partition@30000 {
				label = "factory";
				reg = <0x030000 0x030000>;
				read-only;
			};

			partition@60000 {
				compatible = "denx,uimage";
				label = "firmware";
				reg = <0x060000 0xf10000>;
			};

			partition@f70000 {
				label = "event-log";
				reg = <0xf70000 0x90000>;
				read-only;
			};
		};
	};
};

&wmac {
	status = "okay";
	nvmem-cells = <&macaddr_config_0>;
	nvmem-cell-names = "mac-address";
	mac-address-increment = <2>;
	mediatek,mtd-eeprom = <&factory 0x20000>;
};

&ethernet {
	nvmem-cells = <&macaddr_config_0>;
	nvmem-cell-names = "mac-address";
};

&esw {
	mediatek,portmap = <0x3e>;
};

